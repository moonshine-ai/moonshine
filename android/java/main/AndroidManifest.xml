<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Required only when using the opt-in model auto-download
         (AssetDownloader / MoonshineDownloadWorker). Apps that bundle their
         models do not exercise any networking here, but this permission is
         merged into the consuming app so the download path works out of the
         box. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

</manifest>
